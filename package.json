{
  "name": "mvhs-app-pwa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "^23.0.0",
    "jsbarcode": "^3.11.5",
    "lucide-react": "^1.14.0",
    "moment": "^2.18.1",
    "prop-types": "^15.5.10",
    "react": "18",
    "react-dom": "^18.3.1",
    "react-easy-swipe": "0.0.17",
    "react-ga": "^2.2.0",
    "react-hooks-barcode": "^1.0.4",
    "react-native": "^0.50.0",
    "react-native-datepicker": "^1.6.0",
    "react-native-material-ui": "^1.14.0",
    "react-native-tab-view": "0.0.69",
    "react-redux": "^5.0.6",
    "react-router": "^4.2.0",
    "react-router-dom": "^6.30.3",
    "react-scripts": "^5.0.1",
    "react-virtualized": "^9.11.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@babel/plugin-transform-flow-strip-types": "^7.27.1",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "chalk": "^2.2.0",
    "exp": "^47.0.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^1.3.0"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,json,css,ts}": [
      "prettier --single-quote --write",
      "git add"
    ]
  },
  "main": "./src/index.native.js",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start:expo": "react-native-scripts start",
    "start:android": "react-native-scripts android",
    "deploy:expo": "exp publish"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}"
    ],
    "setupFiles": [
      "<rootDir>/config/polyfills.js"
    ],
    "testMatch": [
      "<rootDir>/src/**/__tests__/**/*.js?(x)",
      "<rootDir>/src/**/?(*.)(spec|test).js?(x)"
    ],
    "testEnvironment": "node",
    "testURL": "http://localhost",
    "transform": {
      "^.+\\.(js|jsx)$": "<rootDir>/node_modules/babel-jest",
      "^.+\\.css$": "<rootDir>/config/jest/cssTransform.js",
      "^(?!.*\\.(js|jsx|css|json)$)": "<rootDir>/config/jest/fileTransform.js"
    },
    "transformIgnorePatterns": [
      "[/\\\\]node_modules[/\\\\].+\\.(js|jsx)$"
    ],
    "moduleNameMapper": {
      "^react-native$": "react-native-web"
    }
  }
}
